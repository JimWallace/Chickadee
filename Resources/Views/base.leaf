<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <title>#import("title") — Chickadee</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png">
    <link rel="shortcut icon" href="/favicon.png" type="image/png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
<a class="skip-link" href="#main-content">Skip to main content</a>
<nav class="nav">
    <a class="nav-brand" href="/">
        <img class="nav-brand-logo" src="/images/chickadee-icon-alt.png" alt="">
        <span>Chickadee</span>
    </a>

    #if(currentUser):
        #if(currentUser.isInstructor):
            <a class="nav-link" href="/assignments">Instructor</a>
        #endif
        #if(currentUser.isAdmin):
            <a class="nav-link" href="/admin">Admin</a>
        #endif
        <a class="nav-link" href="/account" aria-label="My account" style="margin-left:auto">
            #if(currentUser.preferredName):
                #(currentUser.preferredName)
            #elseif(currentUser.displayName):
                #(currentUser.displayName)
            #else:
                #(currentUser.username)
            #endif
        </a>
        <form method="post" action="/logout" style="display:inline;margin:0">
            <button class="btn-link nav-link" type="submit">Log out</button>
        </form>
    #else:
        <a class="nav-link" href="/login">Log in</a>
    #endif
</nav>
#if(currentUser && currentUser.showCourseTabs):
<nav class="course-tabs" aria-label="Courses">
    #for(course in currentUser.enrolledCourses):
    <form method="post" action="/courses/#(course.id)/activate" style="display:contents">
        <button type="submit"
                class="course-tab #if(course.isActive):course-tab-active#endif"
                aria-current="#if(course.isActive):page#else:false#endif">
            #(course.code)
        </button>
    </form>
    #endfor
</nav>
#endif
<main class="main" id="main-content">
    #import("content")
</main>
<script src="/app.js"></script>
</body>
</html>
